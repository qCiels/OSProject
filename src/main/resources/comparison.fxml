<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane minWidth="-Infinity" prefHeight="950.0" prefWidth="1400.0" style="-fx-background-color: #f5f7fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.OperatingSystems.ComparisonController">
   <children>
      <Label layoutX="574.0" layoutY="39.0" prefHeight="55.0" prefWidth="247.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Schedular Comparison" textAlignment="CENTER">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Button fx:id="generateSampleButton" layoutX="14.0" layoutY="289.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="175.0" style="-fx-background-color: #4a90e2; -fx-background-radius: 5; -fx-font-weight: bold; -fx-text-fill: white;" text="GENERATE SAMPLE" />
      <Button fx:id="startComparisonButton" layoutX="14.0" layoutY="334.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="175.0" style="-fx-background-color: #4a90e2; -fx-font-weight: bold; -fx-text-fill: white;" text="START COMPARISON" />
      <Button fx:id="backButton" layoutX="14.0" layoutY="400.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="175.0" style="-fx-background-color: #6c757d; -fx-font-weight: bold; -fx-background-radius: 5; -fx-text-fill: white;" text="BACK" />
      <TableView fx:id="comparisonTable" layoutX="279.0" layoutY="107.0" prefHeight="636.0" prefWidth="842.0" style="-fx-background-color: white; -fx-background-color: #c7c7c7; -fx-border-width: 1;">
        <columns>
          <TableColumn fx:id="algorithmColumn" prefWidth="176.0" text="ALGORITHIM" />
          <TableColumn fx:id="avgWaitingColumn" prefWidth="129.0" text="AVG WAIT. TIME" />
            <TableColumn fx:id="avgTurnaroundColumn" prefWidth="170.0" text="AVG TURNAROUND TIME" />
            <TableColumn fx:id="avgResponseColumn" prefWidth="151.0" text="AVG RESPONSE TIME" />
            <TableColumn fx:id="completionTimeColumn" prefWidth="215.0" text="COMPLETION TIME" />
        </columns>
      </TableView>
      <VBox layoutY="788.0" prefHeight="162.0" prefWidth="1400.0" style="-fx-border-color: #c7c7c7; -fx-background-color: white; -fx-border-width: 1; -fx-padding: 15; -fx-spacing: 8;">
         <children>
            <Label prefHeight="32.0" prefWidth="279.0" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="   Comparison Results :-">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <Label fx:id="bestWaitingLabel" prefHeight="32.0" prefWidth="278.0" style="-fx-text-fill: #374151;" text="  BEST WAITING TIME :-">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <Label fx:id="bestTurnaroundLabel" prefHeight="34.0" prefWidth="277.0" style="-fx-text-fill: #374151;" text="  BEST TURNAROUND TIME :-" textAlignment="CENTER">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <Label fx:id="bestResponseLabel" prefHeight="38.0" prefWidth="277.0" text="  BEST RESPONSE TIME :-" textAlignment="CENTER">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <Label fx:id="bestCompletionLabel" prefHeight="35.0" prefWidth="277.0" text="  BEST COMPLETION TIME :-" textAlignment="CENTER">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </children>
</AnchorPane>
